{
  "name": "bazi-flex-mcp",
  "version": "0.0.1",
  "description": "Flexible Bazi (八字) MCP server — computes charts with or without birth hour. Built on shunshi-bazi-core.",
  "type": "module",
  "license": "MIT",
  "author": "ronload <ron910517@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ronload/bazi-flex-mcp.git"
  },
  "homepage": "https://github.com/ronload/bazi-flex-mcp#readme",
  "bugs": {
    "url": "https://github.com/ronload/bazi-flex-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bazi",
    "八字",
    "四柱推命",
    "四柱八字",
    "chinese-astrology",
    "fortune-telling",
    "saju"
  ],
  "bin": {
    "bazi-flex-mcp": "./dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/transports/http.ts",
    "dev:stdio": "bun run src/transports/stdio.ts",
    "dev:worker": "wrangler dev",
    "build": "bun build src/transports/http.ts --target=bun --outdir=dist --outfile=http.js && bun build src/transports/stdio.ts --target=bun --outdir=dist --outfile=stdio.js",
    "start": "bun run dist/http.js",
    "start:stdio": "bun run dist/stdio.js",
    "deploy": "wrangler deploy --env=\"\"",
    "deploy:prod": "wrangler deploy --env production",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "check:ci": "biome ci ./src"
  },
  "dependencies": {
    "@hono/mcp": "^0.2.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.12.14",
    "shunshi-bazi-core": "^0.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "typescript": "^5.4.0",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
