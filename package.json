{
  "name": "bazi-flex-mcp",
  "version": "0.0.1",
  "description": "Flexible Bazi (八字) MCP server — computes charts with or without birth hour.",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "author": "ronload <ronald@ronaldluo.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ronload/bazi-flex-mcp.git"
  },
  "homepage": "https://github.com/ronload/bazi-flex-mcp#readme",
  "bugs": {
    "url": "https://github.com/ronload/bazi-flex-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bazi",
    "八字",
    "四柱推命",
    "四柱八字",
    "chinese-astrology",
    "fortune-telling",
    "saju"
  ],
  "bin": {
    "bazi-flex-mcp": "./dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/transports/http.ts",
    "dev:stdio": "bun run src/transports/stdio.ts",
    "dev:worker": "wrangler dev",
    "build": "bun build src/transports/http.ts --target=bun --outdir=dist --outfile=http.js && bun build src/transports/stdio.ts --target=bun --outdir=dist --outfile=stdio.js",
    "start": "bun run dist/http.js",
    "start:stdio": "bun run dist/stdio.js",
    "deploy": "wrangler deploy --env=\"\"",
    "deploy:prod": "wrangler deploy --env production",
    "test": "bun test",
    "oracle:check": "bun run test/oracle/cli.ts check",
    "oracle:baseline": "bun run test/oracle/cli.ts baseline",
    "oracle:coverage": "bun run test/oracle/cli.ts coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src ./test ./packages",
    "format": "biome format --write ./src ./test ./packages",
    "check": "biome check --write ./src ./test ./packages",
    "check:ci": "biome ci ./src ./test ./packages"
  },
  "dependencies": {
    "@bazi-flex/core": "workspace:*",
    "@hono/mcp": "^0.3.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.12.31",
    "tyme4ts": "1.4.6",
    "zod": "^4.0.0"
  },
  "overrides": {
    "zod": "~4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "latest",
    "typescript": "^7.0.2",
    "wrangler": "~4.85.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
